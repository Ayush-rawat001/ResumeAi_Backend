{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth_route": {
        "ClusterId": "auth_cluster",
        "Match": {
          "Path": "/api/auth/{**remainder}"
        }
      },
      "resume_route": {
        "ClusterId": "resume_cluster",
        "Match": {
          "Path": "/api/resumes/{**remainder}"
        }
      },
      "section_route": {
        "ClusterId": "section_cluster",
        "Match": {
          "Path": "/api/sections/{**remainder}"
        }
      },
      "ai_route": {
        "ClusterId": "ai_cluster",
        "Match": {
          "Path": "/api/ai/{**remainder}"
        }
      },
      "template_route": {
        "ClusterId": "template_cluster",
        "Match": {
          "Path": "/api/templates/{**remainder}"
        }
      },
      "export_route": {
        "ClusterId": "export_cluster",
        "Match": {
          "Path": "/api/export/{**remainder}"
        }
      },
      "job_search_route": {
        "ClusterId": "job_search_cluster",
        "Match": {
          "Path": "/api/job-search/{**remainder}"
        }
      }
    },
    "Clusters": {
      "auth_cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5150"
          }
        }
      },
      "resume_cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5255"
          }
        }
      },
      "section_cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5257"
          }
        }
      },
      "ai_cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5259"
          }
        }
      },
      "template_cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5108"
          }
        }
      },
      "export_cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5066"
          }
        }
      },
      "job_search_cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5166"
          }
        }
      }
    }
  }
}
